{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "sequoia",
  "name": "Open Impact Docs",
  "colors": {
    "primary": "#3E407B",
    "light": "#9B9CC9",
    "dark": "#2D2E5B"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "getting-started/welcome",
              "getting-started/about-the-platform",
              "getting-started/profile-setup",
              "platform-fundamentals/navigating-the-platform"
            ]
          },
          {
            "group": "Platform Fundamentals",
            "pages": [
              "platform-fundamentals/feed",
              "platform-fundamentals/files",
              "platform-fundamentals/discussions",
              "platform-fundamentals/resource-library",
              "platform-fundamentals/calendar",
              "platform-fundamentals/tasks"
            ]
          },
          {
            "group": "Platform Management",
            "pages": [
              "platform-management/groups",
              "platform-management/projects",
              "platform-management/project-management",
              "platform-management/resource-publishing",
              "platform-management/dashboard_publishing",
              "platform-management/form-publishing",
              "platform-management/event-publishing",
              "platform-management/roles-and-permissions",
              "platform-management/privacy-and-visibility"
            ]
          },
          {
            "group": "Support",
            "pages": [
              "FAQ",
              "contact"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/logo_placeholder.png",
    "dark": "/images/logo_placeholder.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@openfuturecoalition.org"
      },
      {
        "href": "https://www.openfuturecoalition.org/",
        "label": "Open Future Coalition"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Impact",
      "href": "https://impact.openfuturecoalition.org/"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "interaction": {
    "drilldown": true
  },
  "fonts": {
    "family": "Roboto"
  },
  "background": {
    "color": {
      "light": "#F7F8FA",
      "dark": "#181A1D"
    }
  }
}
